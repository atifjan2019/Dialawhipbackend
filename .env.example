APP_NAME="Dialawhip"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://127.0.0.1:8000
APP_FRONTEND_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_LEVEL=info

# Postgres in production; SQLite for local dev works out of the box.
DB_CONNECTION=sqlite
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=catering
# DB_USERNAME=catering
# DB_PASSWORD=secret

BROADCAST_CONNECTION=log
CACHE_STORE=database
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DRIVER=database
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

# Mail — Resend in production
MAIL_MAILER=log
# MAIL_MAILER=resend
# RESEND_API_KEY=re_xxx
MAIL_FROM_ADDRESS="orders@dialawhip.test"
MAIL_FROM_NAME="${APP_NAME}"

# SMS — Twilio
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

# Payments — Stripe
STRIPE_KEY=pk_test_xxx
STRIPE_SECRET=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Postcode lookup
GETADDRESS_API_KEY=

# Business rules
ORDER_REFERENCE_PREFIX=CAT
ORDER_MIN_TOTAL_PENCE=2000
ORDER_LEAD_TIME_HOURS=24
